<div class="max-w-4xl mx-auto p-6">
  <%= render "project_wizard/step_indicator", current_step: 2 %>

  <div class="bg-white border rounded-lg p-6">
    <h2 class="text-xl font-bold mb-2">Credentials zuweisen</h2>
    <p class="text-sm text-gray-500 mb-6">
      Weise vorhandene Credentials dem Projekt zu und vergib Rollen.
      <%= link_to "Neuen Credential erstellen →", new_credential_path(return_to: "wizard"),
        class: "text-blue-600 hover:underline" %>
    </p>

    <%= form_tag wizard_save_step2_projects_path, method: :post do %>
      <div data-controller="credential-rows">
        <div data-credential-rows-target="container">
          <% assignments = @wizard["credential_assignments"].presence || [{ "credential_id" => nil, "role" => nil }] %>
          <% assignments.each do |assignment| %>
            <%= render "project_wizard/credential_row",
              credentials: @credentials,
              selected_credential: assignment["credential_id"],
              selected_role: assignment["role"] %>
          <% end %>
        </div>

        <button type="button"
          data-action="credential-rows#add"
          class="mt-3 text-sm text-blue-600 hover:text-blue-800">
          + Weitere Zuordnung
        </button>

        <template data-credential-rows-target="template">
          <%= render "project_wizard/credential_row",
            credentials: @credentials,
            selected_credential: nil,
            selected_role: nil %>
        </template>
      </div>

      <div class="flex justify-between items-center mt-6 pt-4 border-t">
        <%= link_to "← Zurück", wizard_projects_path,
          class: "text-gray-500 hover:text-gray-700 text-sm" %>
        <%= submit_tag "Weiter →",
          class: "bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
