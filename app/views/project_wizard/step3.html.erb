<div class="max-w-4xl mx-auto p-6">
  <%= render "project_wizard/step_indicator", current_step: 3 %>

  <div class="bg-white border rounded-lg p-6">
    <h2 class="text-xl font-bold mb-4">Pipeline konfigurieren</h2>

    <% templates = {
      "cold_emailing" => {
        name: "Cold Emailing",
        steps: [
          { name: "Import", type: "csv_import", config: {} },
          { name: "Research", type: "ai_agent", config: { task: "research", enable_web_search: true } },
          { name: "Draft", type: "ai_agent", config: { task: "draft" } },
          { name: "Review", type: "human_review", config: {} },
          { name: "Send", type: "send_email", config: {} }
        ]
      }
    } %>

    <%= form_tag wizard_save_step3_projects_path, method: :post do %>
      <div data-controller="pipeline-steps"
           data-pipeline-steps-templates-value="<%= templates.to_json %>">

        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">Vorlage</label>
          <select data-action="pipeline-steps#applyTemplate"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 text-gray-500">
            <option value="">-- Keine Vorlage --</option>
            <% templates.each do |key, tpl| %>
              <option value="<%= key %>"><%= tpl[:name] %></option>
            <% end %>
          </select>
          <p class="text-xs text-gray-400 mt-1">Vorlage auswählen um Steps automatisch zu befüllen.</p>
        </div>

        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">Pipeline Name *</label>
          <%= text_field_tag :pipeline_name, @wizard.dig("pipeline", "name"),
            class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
            required: true, placeholder: "z.B. Cold Emailing",
            data: { pipeline_steps_target: "pipelineName" } %>
          <p class="text-xs text-gray-400 mt-1">Slug wird automatisch generiert.</p>
        </div>

        <h3 class="text-sm font-semibold text-gray-700 mb-3">Pipeline Steps</h3>
        <div data-pipeline-steps-target="container" class="space-y-3">
          <% steps = @wizard["pipeline_steps"].presence || [{ "name" => "", "step_type" => "", "position" => 1, "config" => {} }] %>
          <% steps.each_with_index do |step, index| %>
            <%= render "project_wizard/pipeline_step_row",
              index: index,
              step_name: step["name"],
              step_type: step["step_type"],
              step_config: step["config"] || {} %>
          <% end %>
        </div>

        <button type="button"
          data-action="pipeline-steps#add"
          class="mt-3 text-sm text-blue-600 hover:text-blue-800">
          + Step hinzufügen
        </button>

        <template data-pipeline-steps-target="template">
          <%= render "project_wizard/pipeline_step_row",
            index: "INDEX",
            step_name: "",
            step_type: "",
            step_config: {} %>
        </template>
      </div>

      <div class="flex justify-between items-center mt-6 pt-4 border-t">
        <%= link_to "← Zurück", wizard_step2_projects_path,
          class: "text-gray-500 hover:text-gray-700 text-sm" %>
        <%= submit_tag "Weiter →",
          class: "bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
