<%# locals: (current_step:) %>
<div class="flex items-center justify-center mb-8">
  <% steps = [
    { num: 1, label: "Projekt" },
    { num: 2, label: "Credentials" },
    { num: 3, label: "Pipeline" },
    { num: 4, label: "Fertig" }
  ] %>
  <% steps.each_with_index do |s, i| %>
    <div class="flex items-center">
      <div class="flex items-center justify-center w-8 h-8 rounded-full text-sm font-semibold
        <%= if s[:num] < current_step
              'bg-blue-600 text-white'
            elsif s[:num] == current_step
              'bg-blue-600 text-white ring-4 ring-blue-100'
            else
              'bg-gray-200 text-gray-500'
            end %>">
        <%= s[:num] < current_step ? "✓" : s[:num] %>
      </div>
      <span class="ml-2 text-sm <%= s[:num] == current_step ? 'font-semibold text-gray-900' : 'text-gray-400' %>">
        <%= s[:label] %>
      </span>
      <% if i < steps.length - 1 %>
        <div class="w-12 h-0.5 mx-3 <%= s[:num] < current_step ? 'bg-blue-600' : 'bg-gray-200' %>"></div>
      <% end %>
    </div>
  <% end %>
</div>
