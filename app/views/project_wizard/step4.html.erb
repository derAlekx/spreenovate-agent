<div class="max-w-4xl mx-auto p-6">
  <%= render "project_wizard/step_indicator", current_step: 4 %>

  <div class="bg-white border rounded-lg p-6">
    <h2 class="text-xl font-bold mb-6">Zusammenfassung</h2>

    <%# Projekt %>
    <div class="mb-6">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Projekt</h3>
      <p class="text-lg font-semibold"><%= @wizard.dig("project", "name") %></p>
    </div>

    <%# Credentials %>
    <div class="mb-6">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Credentials</h3>
      <% if @wizard["credential_assignments"].any? %>
        <div class="space-y-1">
          <% @wizard["credential_assignments"].each do |a| %>
            <% cred = @credentials_map[a["credential_id"]] %>
            <div class="flex items-center gap-2 text-sm">
              <span class="inline-block px-2 py-0.5 bg-gray-100 rounded text-xs font-mono"><%= a["role"] %></span>
              <span><%= cred&.key || "Unbekannt" %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400">Keine Credentials zugewiesen.</p>
      <% end %>
    </div>

    <%# Pipeline %>
    <div class="mb-6">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Pipeline</h3>
      <p class="font-semibold"><%= @wizard.dig("pipeline", "name") %></p>
      <p class="text-xs text-gray-400">Slug: <%= @wizard.dig("pipeline", "name")&.parameterize %></p>

      <% if @wizard["pipeline_steps"].any? %>
        <ol class="mt-3 space-y-1">
          <% @wizard["pipeline_steps"].each do |step| %>
            <li class="flex items-center gap-2 text-sm">
              <span class="text-gray-400 font-mono w-6"><%= step["position"] %>.</span>
              <span class="font-medium"><%= step["name"] %></span>
              <span class="text-xs px-2 py-0.5 bg-blue-50 text-blue-700 rounded"><%= step["step_type"] %></span>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-sm text-gray-400 mt-2">Keine Steps konfiguriert.</p>
      <% end %>
    </div>

    <%# Actions %>
    <div class="flex justify-between items-center pt-4 border-t">
      <%= link_to "← Zurück", wizard_step3_projects_path,
        class: "text-gray-500 hover:text-gray-700 text-sm" %>
      <div class="flex gap-3 items-center">
        <%= button_to "Abbrechen", wizard_cancel_projects_path,
          method: :delete,
          class: "text-red-500 hover:text-red-700 text-sm" %>
        <%= button_to "Projekt erstellen", wizard_finish_projects_path,
          class: "bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700" %>
      </div>
    </div>
  </div>
</div>
