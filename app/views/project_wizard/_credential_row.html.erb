<%# locals: (credentials:, selected_credential:, selected_role:) %>
<div class="flex items-center gap-3 mb-3" data-credential-rows-target="row">
  <select name="assignments[][credential_id]"
    class="flex-1 border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
    <option value="">-- Credential wählen --</option>
    <% credentials.each do |c| %>
      <option value="<%= c.id %>" <%= 'selected' if c.id == selected_credential %>>
        <%= c.key %><% if c.description.present? %> (<%= truncate(c.description, length: 40) %>)<% end %>
      </option>
    <% end %>
  </select>

  <select name="assignments[][role]"
    class="w-40 border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
    <option value="">-- Rolle --</option>
    <option value="ai_api_key" <%= 'selected' if selected_role == 'ai_api_key' %>>ai_api_key</option>
    <option value="smtp" <%= 'selected' if selected_role == 'smtp' %>>smtp</option>
  </select>

  <button type="button"
    data-action="credential-rows#remove"
    class="text-red-400 hover:text-red-600 text-sm">
    Entfernen
  </button>
</div>
