<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-2"><%= @project.name %></h1>
  <p class="text-gray-500 mb-6">Settings: <%= @project.settings&.to_json %></p>

  <h2 class="text-lg font-semibold mb-4">Pipelines</h2>

  <% @pipelines.each do |pipeline| %>
    <div class="bg-white border rounded-lg p-4 mb-4 hover:shadow-sm">
      <%= link_to pipeline.name, pipeline, class: "text-lg font-semibold text-blue-600 hover:underline" %>
      <span class="text-gray-400 text-sm ml-2">(<%= pipeline.slug %>)</span>
      <p class="text-gray-500 text-sm mt-1">
        <%= pipeline.pipeline_steps.count %> Steps, <%= pipeline.items.count %> Items
      </p>
    </div>
  <% end %>
</div>
