<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-6">Projects</h1>

  <% @projects.each do |project| %>
    <div class="bg-white border rounded-lg p-4 mb-4 hover:shadow-sm">
      <%= link_to project.name, project, class: "text-xl font-semibold text-blue-600 hover:underline" %>
      <p class="text-gray-500 text-sm mt-1"><%= project.pipelines.count %> Pipeline(s)</p>
    </div>
  <% end %>

  <% if @projects.empty? %>
    <p class="text-gray-400">Keine Projekte vorhanden. Führe <code>bin/rails db:seed</code> aus.</p>
  <% end %>
</div>
