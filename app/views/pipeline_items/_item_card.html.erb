<div class="bg-white dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-xl p-5" id="<%= dom_id(item) %>_card" data-controller="inline-edit">
  <%# Header %>
  <div class="flex items-start justify-between mb-3">
    <div>
      <h3 class="font-medium text-gray-900 dark:text-neutral-100">
        <%= item.data["name"] || "Item ##{item.id}" %>
        <% if item.data["company"] %>
          <span class="text-gray-300 dark:text-neutral-600 font-normal ml-1">&middot;</span>
          <span class="text-gray-500 dark:text-neutral-400 font-normal ml-1"><%= item.data["company"] %></span>
        <% end %>
        <% if item.data["title"] %>
          <span class="text-gray-300 dark:text-neutral-600 font-normal ml-1">&middot;</span>
          <span class="text-gray-400 dark:text-neutral-500 font-normal text-sm ml-1"><%= item.data["title"] %></span>
        <% end %>
      </h3>
      <% if item.data["email"] %>
        <p class="text-sm text-gray-400 dark:text-neutral-600 mt-0.5"><%= item.data["email"] %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <% fit_score = item.data.dig("qualify", "score") %>
      <% if fit_score %>
        <% fit_color = case fit_score
             when 5 then 'bg-emerald-100 dark:bg-emerald-950 text-emerald-700 dark:text-emerald-400'
             when 4 then 'bg-emerald-50 dark:bg-emerald-950/60 text-emerald-600 dark:text-emerald-400'
             when 3 then 'bg-amber-50 dark:bg-amber-950 text-amber-700 dark:text-amber-400'
             when 2 then 'bg-orange-50 dark:bg-orange-950 text-orange-700 dark:text-orange-400'
             when 1 then 'bg-red-50 dark:bg-red-950 text-red-700 dark:text-red-400'
             else 'bg-gray-100 dark:bg-neutral-800 text-gray-500 dark:text-neutral-400'
             end %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium <%= fit_color %>"
          title="<%= item.data.dig('qualify', 'reason') %>">
          Fit <%= fit_score %>/5
        </span>
      <% end %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium
        <%= case item.status
            when 'pending' then 'bg-gray-100 dark:bg-neutral-800 text-gray-500 dark:text-neutral-400'
            when 'processing' then 'bg-blue-50 dark:bg-blue-950 text-blue-600 dark:text-blue-400'
            when 'review' then 'bg-amber-50 dark:bg-amber-950 text-amber-600 dark:text-amber-400'
            when 'approved' then 'bg-emerald-50 dark:bg-emerald-950 text-emerald-600 dark:text-emerald-400'
            when 'rejected' then 'bg-gray-100 dark:bg-neutral-800 text-gray-400 dark:text-neutral-500'
            when 'sent' then 'bg-emerald-50 dark:bg-emerald-950 text-emerald-600 dark:text-emerald-300'
            when 'failed' then 'bg-red-50 dark:bg-red-950 text-red-600 dark:text-red-400'
            else 'bg-gray-100 dark:bg-neutral-800 text-gray-500 dark:text-neutral-400'
            end %>">
        <%= item.status %>
      </span>
    </div>
  </div>

  <%# Qualify reason (shown when fit_score is set) %>
  <% if item.data.dig("qualify", "reason").present? %>
    <p class="mb-3 text-xs text-gray-500 dark:text-neutral-500">
      <span class="text-gray-400 dark:text-neutral-600">Fit-Begründung:</span> <%= item.data.dig("qualify", "reason") %>
    </p>
  <% end %>

  <%# Research %>
  <% if item.data["research"].present? %>
    <details class="mb-3 group">
      <summary class="text-sm text-gray-400 dark:text-neutral-500 cursor-pointer hover:text-gray-600 dark:hover:text-neutral-300 transition">Research</summary>
      <div class="mt-2 p-3 bg-gray-50 dark:bg-neutral-950 rounded-lg text-sm text-gray-500 dark:text-neutral-400 border border-gray-200 dark:border-neutral-800">
        <% if item.data.dig("research", "summary") %>
          <p><%= item.data.dig("research", "summary")
            .gsub(%r{(https?://[^\s,)]+)}) { |url| "<a href=\"#{url}\" target=\"_blank\" class=\"text-blue-500 dark:text-blue-400 underline hover:text-blue-600 dark:hover:text-blue-300\">#{url}</a>" }
            .gsub(/\*\*(.+?)\*\*/m, '<span class="font-medium text-gray-600 dark:text-neutral-300">\1</span>')
            .gsub(/\*(.+?)\*/m, '<em>\1</em>')
            .html_safe %></p>
        <% end %>
        <% if item.data.dig("research", "pain_points").present? %>
          <p class="mt-2 text-gray-700 dark:text-neutral-300">Pain Points:</p>
          <ul class="list-disc list-inside mt-1">
            <% item.data.dig("research", "pain_points").each do |point| %>
              <li><%= point %></li>
            <% end %>
          </ul>
        <% end %>
        <% if item.data.dig("research", "hook_angle") %>
          <p class="mt-2"><span class="text-gray-700 dark:text-neutral-300">Hook:</span> <%= item.data.dig("research", "hook_angle") %></p>
        <% end %>
      </div>
    </details>
  <% end %>

  <% variants = item.data.dig("drafts", "variants") %>
  <% selected_variant = item.data.dig("drafts", "selected_variant") %>
  <% has_ab_variants = variants.present? && variants.size > 1 %>

  <%# A/B Variant Review: tabs with actions + shared comment box for Mark Excellent flow %>
  <% if has_ab_variants && item.status == "review" %>
    <% default_tab = selected_variant ? variants.index { |v| v["variant"] == selected_variant } || 0 : 0 %>
    <div class="mb-4" data-controller="variant-tabs send-comment">
      <div class="flex gap-1 mb-2">
        <% variants.each_with_index do |v, i| %>
          <% is_active_tab = i == default_tab %>
          <% model_label = (v["model"] || "").include?("opus") ? "Opus" : ((v["model"] || "").include?("sonnet") ? "Sonnet" : "") %>
          <button type="button"
            data-action="variant-tabs#switch"
            data-variant-tabs-index-param="<%= i %>"
            data-variant-tabs-target="tab"
            class="px-3 py-1 rounded-md text-xs font-medium transition
              <%= is_active_tab ? 'bg-gray-900 dark:bg-neutral-200 text-white dark:text-neutral-900' : 'bg-gray-100 dark:bg-neutral-800 text-gray-500 dark:text-neutral-400 hover:bg-gray-200 dark:hover:bg-neutral-700' %>">
            Variante <%= v["variant"].upcase %><% if model_label.present? %> · <span class="opacity-70"><%= model_label %></span><% end %>
          </button>
        <% end %>
      </div>

      <% variants.each_with_index do |v, i| %>
        <%# If this variant was selected and edited, show the edited version %>
        <% is_edited = selected_variant == v["variant"] && item.data["draft"].present? %>
        <% display_subject = is_edited ? item.data.dig("draft", "subject") : v["subject"] %>
        <% display_body = is_edited ? item.data.dig("draft", "body") : v["body"] %>
        <% was_modified = is_edited && (display_subject != v["subject"] || display_body != v["body"]) %>

        <div data-variant-tabs-target="panel" class="<%= 'hidden' if i != default_tab %>">
          <%# Read mode %>
          <div data-variant-tabs-target="display<%= i %>">
            <% if was_modified %>
              <p class="text-xs text-amber-500 dark:text-amber-400 mb-1">editiert</p>
            <% end %>
            <p class="text-sm font-medium text-gray-700 dark:text-neutral-300 mb-1"><%= display_subject %></p>
            <div class="text-sm text-gray-500 dark:text-neutral-500 whitespace-pre-line bg-gray-50 dark:bg-neutral-950 rounded-lg p-3 border border-gray-200 dark:border-neutral-800 mb-2"><%= display_body %></div>
          </div>

          <%# Edit mode (hidden by default) %>
          <div data-variant-tabs-target="edit<%= i %>" class="hidden">
            <%= form_tag pipeline_item_path(pipeline, item), method: :patch, data: { turbo_frame: dom_id(item) } do %>
              <%= hidden_field_tag :select_variant, v["variant"] %>
              <div class="mb-2">
                <label class="block text-xs text-gray-400 dark:text-neutral-500 mb-1">Subject</label>
                <%= text_field_tag :subject, display_subject,
                  class: "w-full bg-white dark:bg-neutral-950 border border-gray-300 dark:border-neutral-700 rounded-lg px-3 py-1.5 text-sm text-gray-900 dark:text-neutral-200 focus:outline-none focus:border-gray-500 dark:focus:border-neutral-500" %>
              </div>
              <div class="mb-2">
                <label class="block text-xs text-gray-400 dark:text-neutral-500 mb-1">Body</label>
                <%= text_area_tag :body, display_body,
                  rows: 8,
                  class: "w-full bg-white dark:bg-neutral-950 border border-gray-300 dark:border-neutral-700 rounded-lg px-3 py-1.5 text-sm text-gray-900 dark:text-neutral-200 focus:outline-none focus:border-gray-500 dark:focus:border-neutral-500" %>
              </div>
              <div class="flex gap-2">
                <%= submit_tag "Save", class: "bg-amber-600 dark:bg-amber-700 text-white px-3 py-1.5 rounded-lg text-sm hover:bg-amber-500 dark:hover:bg-amber-600 cursor-pointer transition" %>
                <button type="button" data-action="variant-tabs#cancelEdit" data-variant-tabs-index-param="<%= i %>" class="text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition">Cancel</button>
              </div>
            <% end %>
          </div>

          <%# Actions for this variant %>
          <div class="flex flex-wrap items-center gap-2 pt-2">
            <%= form_with url: select_variant_pipeline_item_path(pipeline, item, variant: v["variant"]), method: :post, data: { turbo_frame: dom_id(item) } do |f| %>
              <%= hidden_field_tag :approve, "true" %>
              <%= hidden_field_tag :user_comment, "", data: { send_comment_target: "hidden" } %>
              <%= f.submit "Approve #{v["variant"].upcase}",
                class: "bg-emerald-600 dark:bg-emerald-800 text-white dark:text-emerald-100 px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-emerald-500 dark:hover:bg-emerald-700 transition cursor-pointer" %>
            <% end %>

            <%= form_with url: select_variant_pipeline_item_path(pipeline, item, variant: v["variant"]), method: :post, data: { turbo_frame: dom_id(item), turbo_confirm: "#{v["variant"].upcase} approven UND als herausragend markieren?" } do |f| %>
              <%= hidden_field_tag :approve, "true" %>
              <%= hidden_field_tag :mark_excellent, "true" %>
              <%= hidden_field_tag :user_comment, "", data: { send_comment_target: "hidden" } %>
              <%= f.submit "Approve #{v["variant"].upcase} + Mark Excellent",
                class: "bg-emerald-800 dark:bg-emerald-900 text-white px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-emerald-700 dark:hover:bg-emerald-800 transition cursor-pointer" %>
            <% end %>

            <%= button_to "Skip", skip_pipeline_item_path(pipeline, item),
              class: "text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-4 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
            <button type="button" data-action="variant-tabs#toggleEdit" data-variant-tabs-index-param="<%= i %>" class="text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-4 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition">Edit</button>
            <%= button_to "Redraft", redraft_pipeline_item_path(pipeline, item),
              class: "text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-4 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
          </div>
        </div>
      <% end %>

      <%# Shared comment box — synced into all Approve forms via Stimulus %>
      <div class="mt-3 pt-3 border-t border-gray-100 dark:border-neutral-800">
        <label class="block text-xs text-gray-400 dark:text-neutral-500 mb-1">Kommentar (optional, wird mitgespeichert)</label>
        <textarea
          data-send-comment-target="input"
          rows="2"
          placeholder="Was gut/nicht gut? Hilft später beim Lernen."
          class="w-full bg-white dark:bg-neutral-950 border border-gray-300 dark:border-neutral-700 rounded-lg px-3 py-1.5 text-sm text-gray-900 dark:text-neutral-200 focus:outline-none focus:border-gray-500 dark:focus:border-neutral-500"></textarea>
      </div>
    </div>

  <% elsif item.data["draft"].present? %>
    <%# Single draft (no variants, or non-review status) %>
    <div class="mb-4">
      <div data-inline-edit-target="display">
        <p class="text-sm font-medium text-gray-700 dark:text-neutral-300 mb-1"><%= item.data.dig("draft", "subject") %></p>
        <div class="text-sm text-gray-500 dark:text-neutral-500 whitespace-pre-line bg-gray-50 dark:bg-neutral-950 rounded-lg p-3 border border-gray-200 dark:border-neutral-800"><%= item.data.dig("draft", "body") %></div>
      </div>

      <div data-inline-edit-target="form" class="hidden">
        <%= form_tag pipeline_item_path(pipeline, item), method: :patch, data: { turbo_frame: dom_id(item) } do %>
          <div class="mb-2">
            <label class="block text-xs text-gray-400 dark:text-neutral-500 mb-1">Subject</label>
            <%= text_field_tag :subject, item.data.dig("draft", "subject"),
              class: "w-full bg-white dark:bg-neutral-950 border border-gray-300 dark:border-neutral-700 rounded-lg px-3 py-1.5 text-sm text-gray-900 dark:text-neutral-200 focus:outline-none focus:border-gray-500 dark:focus:border-neutral-500" %>
          </div>
          <div class="mb-2">
            <label class="block text-xs text-gray-400 dark:text-neutral-500 mb-1">Body</label>
            <%= text_area_tag :body, item.data.dig("draft", "body"),
              rows: 8,
              class: "w-full bg-white dark:bg-neutral-950 border border-gray-300 dark:border-neutral-700 rounded-lg px-3 py-1.5 text-sm text-gray-900 dark:text-neutral-200 focus:outline-none focus:border-gray-500 dark:focus:border-neutral-500" %>
          </div>
          <div class="flex gap-2">
            <%= submit_tag "Save", class: "bg-amber-600 dark:bg-amber-700 text-white px-3 py-1.5 rounded-lg text-sm hover:bg-amber-500 dark:hover:bg-amber-600 cursor-pointer transition" %>
            <button type="button" data-action="inline-edit#cancel" class="text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition">Cancel</button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Processing indicator %>
  <% if item.status == "processing" %>
    <div class="flex items-center gap-2 p-3 bg-blue-50 dark:bg-blue-950/30 border border-blue-200 dark:border-blue-900/30 rounded-lg text-sm text-blue-600 dark:text-blue-400 mb-3">
      <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Processing... (<%= item.current_step&.name || "Step" %>)
    </div>
  <% end %>

  <%# Failed error %>
  <% if item.status == "failed" %>
    <% last_error = item.item_events.where(event_type: "error").order(created_at: :desc).first %>
    <% if last_error %>
      <div class="p-3 bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-900/30 rounded-lg text-sm text-red-600 dark:text-red-400 mb-3">
        <%= last_error.note %>
      </div>
    <% end %>
  <% end %>

  <%# Actions (only for non-variant review or other statuses) %>
  <% unless has_ab_variants && item.status == "review" %>
    <% if item.status == "pending" %>
      <div class="flex items-center gap-2 pt-3 border-t border-gray-100 dark:border-neutral-800">
        <%= button_to "Process", process_item_pipeline_item_path(pipeline, item),
          class: "bg-blue-600 dark:bg-blue-700 text-white px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-blue-500 dark:hover:bg-blue-600 transition" %>
        <%= button_to "Skip", skip_pipeline_item_path(pipeline, item),
          class: "text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-4 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
      </div>
    <% elsif item.status == "review" %>
      <div class="flex items-center gap-2 pt-3 border-t border-gray-100 dark:border-neutral-800">
        <%= button_to "Approve", approve_pipeline_item_path(pipeline, item),
          class: "bg-emerald-600 dark:bg-emerald-800 text-white dark:text-emerald-100 px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-emerald-500 dark:hover:bg-emerald-700 transition" %>
        <%= button_to "Skip", skip_pipeline_item_path(pipeline, item),
          class: "text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-4 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
        <% if item.data["draft"].present? %>
          <button type="button" data-action="inline-edit#toggle" class="text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-4 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition">Edit</button>
          <%= button_to "Redraft", redraft_pipeline_item_path(pipeline, item),
            class: "text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-4 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
        <% end %>
      </div>
    <% elsif item.status == "approved" %>
      <% can_send = pipeline.remaining_sends_today > 0 %>
      <% if item.data["marked_excellent"] == true %>
        <div class="mb-2 text-xs text-emerald-700 dark:text-emerald-400">★ Als herausragend markiert</div>
      <% end %>
      <% if item.data["user_comment"].present? %>
        <div class="mb-2 p-2 bg-gray-50 dark:bg-neutral-950 border border-gray-200 dark:border-neutral-800 rounded text-xs text-gray-500 dark:text-neutral-400">
          <span class="text-gray-400 dark:text-neutral-600">Kommentar:</span> <%= item.data["user_comment"] %>
        </div>
      <% end %>
      <div class="flex items-center gap-2 pt-3 border-t border-gray-100 dark:border-neutral-800">
        <%= button_to "Send", send_email_pipeline_item_path(pipeline, item),
          class: "px-4 py-1.5 rounded-lg text-sm font-medium transition #{can_send ? 'bg-amber-600 dark:bg-amber-700 text-white hover:bg-amber-500 dark:hover:bg-amber-600' : 'bg-gray-200 dark:bg-neutral-800 text-gray-400 dark:text-neutral-600 cursor-not-allowed'}",
          disabled: !can_send,
          data: can_send ? { turbo_confirm: "Email an #{item.data['email']} senden?" } : {} %>
        <%= button_to "Reset", reset_pipeline_item_path(pipeline, item),
          class: "text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
      </div>
    <% elsif item.status == "rejected" %>
      <div class="flex items-center gap-2 pt-3 border-t border-gray-100 dark:border-neutral-800">
        <%= button_to "Reset", reset_pipeline_item_path(pipeline, item),
          class: "text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
      </div>
    <% elsif item.status == "failed" %>
      <div class="flex items-center gap-2 pt-3 border-t border-gray-100 dark:border-neutral-800">
        <%= button_to "Retry", retry_pipeline_item_path(pipeline, item),
          class: "bg-amber-600 dark:bg-amber-700 text-white px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-amber-500 dark:hover:bg-amber-600 transition" %>
        <%= button_to "Skip", skip_pipeline_item_path(pipeline, item),
          class: "text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-4 py-1.5 rounded-lg text-sm hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
      </div>
    <% end %>
  <% end %>
</div>
