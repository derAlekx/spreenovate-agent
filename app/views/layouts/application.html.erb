<!DOCTYPE html>
<html data-controller="theme">
  <head>
    <title><%= content_for(:title) || "Spreenovate Agent" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      (function() {
        var s = localStorage.getItem('theme');
        var d = s ? s === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (d) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>

  <body class="bg-gray-50 dark:bg-neutral-950 text-gray-900 dark:text-neutral-200 min-h-screen antialiased transition-colors">
    <nav class="border-b border-gray-200 dark:border-neutral-800">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-8">
          <%= link_to "spreenovate", root_path,
            class: "text-base font-medium text-gray-900 dark:text-neutral-100 tracking-tight" %>
          <div class="flex items-center gap-5 text-sm">
            <%= link_to "Projects", projects_path,
              class: "transition #{controller_name.in?(%w[projects project_wizard pipelines pipeline_items]) ? 'text-gray-900 dark:text-neutral-100' : 'text-gray-500 dark:text-neutral-500 hover:text-gray-700 dark:hover:text-neutral-300'}" %>
            <%= link_to "Credentials", credentials_path,
              class: "transition #{controller_name == 'credentials' ? 'text-gray-900 dark:text-neutral-100' : 'text-gray-500 dark:text-neutral-500 hover:text-gray-700 dark:hover:text-neutral-300'}" %>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <button data-action="theme#toggle" class="text-gray-400 dark:text-neutral-500 hover:text-gray-600 dark:hover:text-neutral-300 transition p-1.5" title="Toggle theme">
            <svg class="w-4 h-4 block dark:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
            </svg>
            <svg class="w-4 h-4 hidden dark:block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
            </svg>
          </button>
          <%= link_to "+ New Project", wizard_projects_path,
            class: "text-sm text-gray-500 dark:text-neutral-400 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg hover:text-gray-700 dark:hover:text-neutral-200 hover:border-gray-400 dark:hover:border-neutral-500 transition" %>
        </div>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="max-w-5xl mx-auto mt-4 px-6">
        <div class="bg-emerald-50 dark:bg-emerald-950/50 border border-emerald-200 dark:border-emerald-800/50 text-emerald-700 dark:text-emerald-300 rounded-lg px-4 py-2.5 text-sm"><%= notice %></div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="max-w-5xl mx-auto mt-4 px-6">
        <div class="bg-red-50 dark:bg-red-950/50 border border-red-200 dark:border-red-800/50 text-red-700 dark:text-red-300 rounded-lg px-4 py-2.5 text-sm"><%= alert %></div>
      </div>
    <% end %>

    <main class="mt-6">
      <%= yield %>
    </main>
  </body>
</html>
