<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Spreenovate Agent" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-neutral-950 text-neutral-200 min-h-screen antialiased">
    <nav class="border-b border-neutral-800">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-8">
          <%= link_to "spreenovate", root_path,
            class: "text-base font-medium text-neutral-100 tracking-tight" %>
          <div class="flex items-center gap-5 text-sm">
            <%= link_to "Projects", projects_path,
              class: "transition #{controller_name.in?(%w[projects project_wizard pipelines pipeline_items]) ? 'text-neutral-100' : 'text-neutral-500 hover:text-neutral-300'}" %>
            <%= link_to "Credentials", credentials_path,
              class: "transition #{controller_name == 'credentials' ? 'text-neutral-100' : 'text-neutral-500 hover:text-neutral-300'}" %>
          </div>
        </div>
        <%= link_to "+ New Project", wizard_projects_path,
          class: "text-sm text-neutral-400 border border-neutral-700 px-3 py-1.5 rounded-lg hover:text-neutral-200 hover:border-neutral-500 transition" %>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="max-w-5xl mx-auto mt-4 px-6">
        <div class="bg-emerald-950/50 border border-emerald-800/50 text-emerald-300 rounded-lg px-4 py-2.5 text-sm"><%= notice %></div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="max-w-5xl mx-auto mt-4 px-6">
        <div class="bg-red-950/50 border border-red-800/50 text-red-300 rounded-lg px-4 py-2.5 text-sm"><%= alert %></div>
      </div>
    <% end %>

    <main class="mt-6">
      <%= yield %>
    </main>
  </body>
</html>
