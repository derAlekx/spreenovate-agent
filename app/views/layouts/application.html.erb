<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Spreenovate Agent" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 min-h-screen">
    <% if notice.present? %>
      <div class="max-w-4xl mx-auto mt-4 px-6">
        <div class="bg-green-100 border border-green-300 text-green-800 rounded p-3 text-sm"><%= notice %></div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="max-w-4xl mx-auto mt-4 px-6">
        <div class="bg-red-100 border border-red-300 text-red-800 rounded p-3 text-sm"><%= alert %></div>
      </div>
    <% end %>

    <main class="mt-4">
      <%= yield %>
    </main>
  </body>
</html>
