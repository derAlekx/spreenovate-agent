<div class="max-w-5xl mx-auto px-6 pb-12">
  <%# Header %>
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-sm text-gray-400 dark:text-neutral-500 mb-1">
        <%= link_to "Projects", projects_path, class: "hover:text-gray-600 dark:hover:text-neutral-300 transition" %> /
        <%= link_to @pipeline.project.name, project_path(@pipeline.project), class: "hover:text-gray-600 dark:hover:text-neutral-300 transition" %>
      </p>
      <h1 class="text-xl font-medium text-gray-900 dark:text-neutral-100"><%= @pipeline.name %></h1>
    </div>
    <div class="flex items-center gap-3">
      <% approved_count = @pipeline.items.where(status: "approved").count %>
      <% sent_today = @pipeline.sent_today_count %>
      <% remaining = @pipeline.remaining_sends_today %>
      <% daily_limit = @pipeline.daily_limit %>
      <% send_count = [remaining, approved_count].min %>
      <% can_send = send_count > 0 %>

      <% if approved_count > 0 %>
        <%= button_to "Testmail", test_send_pipeline_path(@pipeline),
          class: "text-sm text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition",
          data: { turbo_confirm: "Testmail an eigene Adresse senden?" } %>
      <% end %>

      <%= button_to "Send #{send_count}/#{daily_limit}",
        bulk_send_pipeline_path(@pipeline),
        class: "text-sm px-4 py-1.5 rounded-lg font-medium transition #{can_send ? 'bg-amber-600 dark:bg-amber-700 text-white hover:bg-amber-500 dark:hover:bg-amber-600' : 'bg-gray-200 dark:bg-neutral-800 text-gray-400 dark:text-neutral-600 cursor-not-allowed'}",
        disabled: !can_send,
        data: can_send ? { turbo_confirm: "#{send_count} Emails jetzt senden?" } : {} %>

      <%= form_tag import_csv_pipeline_path(@pipeline), multipart: true, class: "flex items-center gap-2" do %>
        <%= file_field_tag :csv_file, accept: ".csv", class: "text-sm text-gray-500 dark:text-neutral-500 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border file:border-gray-300 dark:file:border-neutral-700 file:text-sm file:text-gray-500 dark:file:text-neutral-400 file:bg-transparent hover:file:border-gray-400 dark:hover:file:border-neutral-500 file:cursor-pointer file:transition" %>
        <%= submit_tag "Import", class: "text-sm text-gray-500 dark:text-neutral-400 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg hover:text-gray-700 dark:hover:text-neutral-200 hover:border-gray-400 dark:hover:border-neutral-500 transition cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <%# Status Bar %>
  <%= turbo_frame_tag "status_bar" do %>
    <%= render partial: "pipelines/status_bar", locals: { pipeline: @pipeline } %>
  <% end %>

  <%# Filter Tabs %>
  <div class="flex gap-1 mb-6">
    <% filters = [
      ["All", "all"],
      ["Pending", "pending"],
      ["Processing", "processing"],
      ["Review", "review"],
      ["Approved", "approved"],
      ["Skipped", "skipped"],
      ["Failed", "failed"],
      ["Sent", "sent"]
    ] %>
    <% filters.each do |label, value| %>
      <%= link_to label, pipeline_path(@pipeline, filter: value),
        class: "px-3 py-1.5 rounded-lg text-sm transition #{@filter == value ? 'bg-gray-200 dark:bg-neutral-800 text-gray-900 dark:text-neutral-100' : 'text-gray-500 dark:text-neutral-500 hover:text-gray-700 dark:hover:text-neutral-300'}" %>
    <% end %>
  </div>

  <%# Bulk Actions %>
  <% if @filter == "review" && @items.any? %>
    <div class="flex gap-2 mb-4">
      <%= button_to "Approve all", bulk_approve_pipeline_items_path(@pipeline, filter: @filter),
        class: "text-sm text-gray-500 dark:text-neutral-400 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg hover:text-gray-700 dark:hover:text-neutral-200 hover:border-gray-400 dark:hover:border-neutral-500 transition",
        data: { turbo_confirm: "Alle #{@items.count} Items approven?" } %>
    </div>
  <% end %>

  <% if %w[approved skipped].include?(@filter) && @items.any? %>
    <div class="flex gap-2 mb-4">
      <%= button_to "Reset all", bulk_reset_pipeline_items_path(@pipeline, filter: @filter),
        class: "text-sm text-gray-500 dark:text-neutral-500 border border-gray-300 dark:border-neutral-700 px-3 py-1.5 rounded-lg hover:text-gray-700 dark:hover:text-neutral-300 hover:border-gray-400 dark:hover:border-neutral-500 transition",
        data: { turbo_confirm: "Alle Items zurück auf Review setzen?" } %>
    </div>
  <% end %>

  <%# Item Cards %>
  <div class="space-y-3">
    <% @items.each do |item| %>
      <%= turbo_frame_tag dom_id(item) do %>
        <%= render partial: "pipeline_items/item_card", locals: { item: item, pipeline: @pipeline } %>
      <% end %>
    <% end %>

    <% if @items.empty? %>
      <div class="text-center py-12 text-gray-400 dark:text-neutral-600 text-sm">
        No items with status "<%= @filter %>".
      </div>
    <% end %>
  </div>
</div>
