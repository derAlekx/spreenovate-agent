<div class="max-w-4xl mx-auto p-6 bg-gray-50 min-h-screen">
  <%# Header %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="text-sm text-gray-500">
        <%= link_to "Projects", projects_path, class: "hover:text-gray-700" %> /
        <%= link_to @pipeline.project.name, project_path(@pipeline.project), class: "hover:text-gray-700" %>
      </p>
      <h1 class="text-2xl font-bold text-gray-900"><%= @pipeline.name %></h1>
    </div>
    <div class="flex items-center gap-3">
      <% approved_count = @pipeline.items.where(status: "approved").count %>
      <% if approved_count > 0 %>
        <%= button_to "Testmail", test_send_pipeline_path(@pipeline),
          class: "bg-gray-200 text-gray-700 px-3 py-1.5 rounded text-sm hover:bg-gray-300",
          data: { turbo_confirm: "Testmail an eigene Adresse senden?" } %>
        <%= button_to "#{approved_count} Emails senden", bulk_send_pipeline_path(@pipeline),
          class: "bg-emerald-600 text-white px-3 py-1.5 rounded text-sm hover:bg-emerald-700",
          data: { turbo_confirm: "#{approved_count} Emails jetzt senden?" } %>
      <% end %>
      <div class="bg-white border rounded-lg p-3 shadow-sm">
        <h2 class="text-xs font-medium text-gray-500 mb-1">CSV Import</h2>
        <%= form_tag import_csv_pipeline_path(@pipeline), multipart: true, class: "flex items-center gap-2" do %>
          <%= file_field_tag :csv_file, accept: ".csv", class: "text-sm w-48" %>
          <%= submit_tag "Importieren", class: "bg-blue-600 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Status Bar %>
  <%= turbo_frame_tag "status_bar" do %>
    <%= render partial: "pipelines/status_bar", locals: { pipeline: @pipeline } %>
  <% end %>

  <%# Filter Tabs %>
  <div class="flex gap-1 mb-6">
    <% filters = [
      ["Alle", "all"],
      ["Pending", "pending"],
      ["Processing", "processing"],
      ["Review", "review"],
      ["Approved", "approved"],
      ["Skipped", "skipped"],
      ["Failed", "failed"],
      ["Sent", "sent"]
    ] %>
    <% filters.each do |label, value| %>
      <%= link_to label, pipeline_path(@pipeline, filter: value),
        class: "px-3 py-1.5 rounded-md text-sm font-medium #{@filter == value ? 'bg-gray-900 text-white' : 'bg-white text-gray-600 hover:bg-gray-100 border'}" %>
    <% end %>
  </div>

  <%# Bulk Actions (only on review tab) %>
  <% if @filter == "review" && @items.any? %>
    <div class="flex gap-2 mb-4">
      <%= button_to "Alle approven", bulk_approve_pipeline_items_path(@pipeline, filter: @filter),
        class: "bg-green-600 text-white px-3 py-1.5 rounded text-sm hover:bg-green-700",
        data: { turbo_confirm: "Alle #{@items.count} Items approven?" } %>
    </div>
  <% end %>

  <% if %w[approved skipped].include?(@filter) && @items.any? %>
    <div class="flex gap-2 mb-4">
      <%= button_to "Alle zurücksetzen", bulk_reset_pipeline_items_path(@pipeline, filter: @filter),
        class: "bg-gray-200 text-gray-700 px-3 py-1.5 rounded text-sm hover:bg-gray-300",
        data: { turbo_confirm: "Alle Items zurück auf Review setzen?" } %>
    </div>
  <% end %>

  <%# Item Cards %>
  <div class="space-y-4">
    <% @items.each do |item| %>
      <%= turbo_frame_tag dom_id(item) do %>
        <%= render partial: "pipeline_items/item_card", locals: { item: item, pipeline: @pipeline } %>
      <% end %>
    <% end %>

    <% if @items.empty? %>
      <div class="bg-white border rounded-lg shadow-sm p-8 text-center text-gray-400">
        Keine Items mit Status "<%= @filter %>".
      </div>
    <% end %>
  </div>
</div>
