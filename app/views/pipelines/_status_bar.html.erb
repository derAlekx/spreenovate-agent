<% counts = {
  total: pipeline.items.count,
  review: pipeline.items.where(status: "review").count,
  processing: pipeline.items.where(status: "processing").count,
  approved: pipeline.items.where(status: "approved").count,
  skipped: pipeline.items.where(status: "rejected").count,
  pending: pipeline.items.where(status: "pending").count,
  failed: pipeline.items.where(status: "failed").count,
  sent: pipeline.items.where(status: "sent").count
} %>

<div class="bg-white border rounded-lg shadow-sm p-4 mb-6">
  <div class="flex items-center gap-6 text-sm flex-wrap">
    <div>
      <span class="text-gray-500">Total</span>
      <span class="font-semibold ml-1"><%= counts[:total] %></span>
    </div>
    <div>
      <span class="inline-block w-2 h-2 rounded-full bg-yellow-400 mr-1"></span>
      <span class="text-gray-500">Review</span>
      <span class="font-semibold ml-1"><%= counts[:review] %></span>
    </div>
    <div>
      <span class="inline-block w-2 h-2 rounded-full bg-blue-400 mr-1"></span>
      <span class="text-gray-500">Processing</span>
      <span class="font-semibold ml-1"><%= counts[:processing] %></span>
    </div>
    <div>
      <span class="inline-block w-2 h-2 rounded-full bg-green-500 mr-1"></span>
      <span class="text-gray-500">Approved</span>
      <span class="font-semibold ml-1"><%= counts[:approved] %></span>
    </div>
    <div>
      <span class="inline-block w-2 h-2 rounded-full bg-red-400 mr-1"></span>
      <span class="text-gray-500">Skipped</span>
      <span class="font-semibold ml-1"><%= counts[:skipped] %></span>
    </div>
    <div>
      <span class="inline-block w-2 h-2 rounded-full bg-gray-400 mr-1"></span>
      <span class="text-gray-500">Pending</span>
      <span class="font-semibold ml-1"><%= counts[:pending] %></span>
    </div>
    <% if counts[:failed] > 0 %>
    <div>
      <span class="inline-block w-2 h-2 rounded-full bg-red-600 mr-1"></span>
      <span class="text-gray-500">Failed</span>
      <span class="font-semibold ml-1 text-red-600"><%= counts[:failed] %></span>
    </div>
    <% end %>
    <div>
      <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 mr-1"></span>
      <span class="text-gray-500">Sent</span>
      <span class="font-semibold ml-1"><%= counts[:sent] %></span>
    </div>
  </div>
</div>
