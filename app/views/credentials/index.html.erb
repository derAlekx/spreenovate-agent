<div class="max-w-4xl mx-auto p-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Credentials</h1>
    <%= link_to "+ Neuer Credential", new_credential_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" %>
  </div>

  <% @credentials.each do |credential| %>
    <div class="bg-white border rounded-lg p-4 mb-3 flex items-center justify-between">
      <div>
        <span class="font-semibold font-mono text-sm"><%= credential.key %></span>
        <% if credential.description.present? %>
          <span class="text-gray-400 text-sm ml-2"><%= credential.description %></span>
        <% end %>
        <p class="text-xs text-gray-400 mt-1">Wert: ••••••••</p>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-xs text-gray-400">
          <%= credential.projects.count %> Projekt(e)
        </span>
        <%= link_to "Bearbeiten", edit_credential_path(credential),
          class: "text-blue-600 hover:underline text-sm" %>
        <% if credential.project_credentials.empty? %>
          <%= button_to "Löschen", credential_path(credential),
            method: :delete,
            class: "text-red-500 hover:text-red-700 text-sm",
            data: { turbo_confirm: "Credential '#{credential.key}' wirklich löschen?" } %>
        <% else %>
          <span class="text-xs text-gray-300" title="In Verwendung — kann nicht gelöscht werden">Löschen</span>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @credentials.empty? %>
    <div class="bg-white border rounded-lg p-8 text-center text-gray-400">
      Keine Credentials vorhanden.
    </div>
  <% end %>
</div>
