<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-6">
    <%= credential.new_record? ? "Neuer Credential" : "Credential bearbeiten" %>
  </h1>

  <div class="bg-white border rounded-lg p-6">
    <%= form_with model: credential, local: true do |f| %>
      <% if credential.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded p-3 mb-4 text-sm text-red-700">
          <% credential.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <% if local_assigns[:return_to].present? %>
        <%= hidden_field_tag :return_to, return_to %>
      <% end %>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Key *</label>
        <% if credential.persisted? %>
          <p class="text-sm font-mono text-gray-500 py-2"><%= credential.key %></p>
          <%= f.hidden_field :key %>
        <% else %>
          <%= f.text_field :key,
            class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
            placeholder: "z.B. anthropic_api_key" %>
        <% end %>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Wert *</label>
        <%= f.text_field :value,
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
          placeholder: "sk-..." %>
        <% if credential.persisted? %>
          <p class="text-xs text-gray-400 mt-1">Aktuellen Wert ersetzen.</p>
        <% end %>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">Beschreibung</label>
        <%= f.text_field :description,
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
          placeholder: "Wofür wird dieser Credential verwendet?" %>
      </div>

      <div class="flex justify-between items-center">
        <%= link_to "Abbrechen",
          local_assigns[:return_to] == "wizard" ? wizard_step2_projects_path : credentials_path,
          class: "text-gray-500 hover:text-gray-700 text-sm" %>
        <%= f.submit "Speichern",
          class: "bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
