<h1 class="text-2xl font-bold mb-6">Dashboard</h1>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <% @projects.each do |project| %>
    <% project.pipelines.each do |pipeline| %>
      <div class="bg-white border rounded-lg p-5 hover:shadow-sm transition-shadow">
        <div class="text-xs text-gray-400 uppercase tracking-wider font-medium"><%= project.name %></div>
        <h2 class="font-semibold text-lg mb-3">
          <%= link_to pipeline.name, pipeline_path(pipeline), class: "hover:text-blue-600" %>
        </h2>

        <div class="grid grid-cols-3 gap-3 text-sm">
          <div class="text-center p-2 bg-gray-50 rounded">
            <div class="text-xl font-bold text-gray-900"><%= pipeline.items.size %></div>
            <div class="text-gray-500 text-xs">Total</div>
          </div>
          <div class="text-center p-2 bg-yellow-50 rounded">
            <div class="text-xl font-bold text-yellow-700"><%= pipeline.items.count { |i| i.status == "review" } %></div>
            <div class="text-yellow-600 text-xs">Review</div>
          </div>
          <div class="text-center p-2 bg-green-50 rounded">
            <div class="text-xl font-bold text-green-700"><%= pipeline.items.count { |i| i.status == "approved" } %></div>
            <div class="text-green-600 text-xs">Approved</div>
          </div>
        </div>

        <div class="flex gap-3 mt-3 text-xs text-gray-500">
          <span class="text-emerald-600"><%= pipeline.items.count { |i| i.status == "sent" } %> sent</span>
          <span class="text-blue-600"><%= pipeline.items.count { |i| i.status == "processing" } %> processing</span>
          <span class="text-red-600"><%= pipeline.items.count { |i| i.status == "failed" } %> failed</span>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<% if @projects.empty? %>
  <div class="bg-white border rounded-lg p-8 text-center text-gray-400">
    Keine Projekte vorhanden. Starte mit <code class="bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">bin/rails db:seed</code>.
  </div>
<% end %>
